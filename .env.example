ANTHROPIC_API_KEY=

# Read-only IMAP ingestion (--source imap). Optional, just for direct IMAP email ingestion.
# IMAP_PASS must be an app specific password. Do not use your real gmail password, I wouldn't trust me with that. See readme for help.
IMAP_HOST=imap.gmail.com
IMAP_USER=your email here
IMAP_PASS=
IMAP_FOLDER=INBOX
# Folder that approved replies are saved into as drafts (never sent). Default: Drafts.
# Gmail's drafts mailbox is "[Gmail]/Drafts", so use this if you're on Gmail.
IMAP_DRAFTS_FOLDER=[Gmail]/Drafts
